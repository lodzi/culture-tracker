{
  "name": "culture-tracker",
  "version": "1.0.0",
  "private": true,
  "description": "A lightweight daily culture brief — static frontend + Node.js update script powered by Claude.",
  "scripts": {
    "update": "node scripts/fetch-and-summarize.js",
    "email": "node scripts/send-email.js",
    "daily": "npm run update && npm run email",
    "check-sources": "node scripts/check-sources.js",
    "serve": "npx --yes http-server . -p 8080 -c-1"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "nodemailer": "^6.9.14",
    "rss-parser": "^3.13.0"
  }
}
